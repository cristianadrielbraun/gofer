GO_ENV=development

# HTTP boundary. The default listener is loopback-only.
GOFER_ADDR=127.0.0.1:8090
GOFER_BASE_URL=http://local.localhost:8090
# Explicitly unsafe escape hatch for trusted network/container setups without app authentication.
GOFER_ALLOW_UNAUTHENTICATED_REMOTE=false

# Auth (set to true to enable OAuth login; provider credentials are also used for OAuth mail accounts)
GOFER_AUTH_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT=common

# Optional Web Push override. If omitted, Gofer generates and stores keys next to the DB.
GOFER_VAPID_PUBLIC_KEY=
GOFER_VAPID_PRIVATE_KEY=
GOFER_VAPID_SUBJECT=mailto:gofer@gofer.email
