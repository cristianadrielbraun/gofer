GO_ENV=development

# Auth (set to true to enable Google OAuth2)
GOFER_AUTH_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOFER_BASE_URL=http://localhost:8090

# Optional Web Push override. If omitted, Gofer generates and stores keys next to the DB.
GOFER_VAPID_PUBLIC_KEY=
GOFER_VAPID_PRIVATE_KEY=
GOFER_VAPID_SUBJECT=mailto:gofer@gofer.email
