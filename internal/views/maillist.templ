package views

import (
	"fmt"
	"github.com/cristianadrielbraun/gofer/internal/models"

	"github.com/cristianadrielbraun/gofer/components/button"
	"github.com/cristianadrielbraun/gofer/components/calendar"
	"github.com/cristianadrielbraun/gofer/components/dialog"
	"github.com/cristianadrielbraun/gofer/components/dropdown"
	"github.com/cristianadrielbraun/gofer/components/icon"
	"github.com/cristianadrielbraun/gofer/components/input"
	"github.com/cristianadrielbraun/gofer/components/selectbox"
	switchcomp "github.com/cristianadrielbraun/gofer/components/switch"
	"github.com/cristianadrielbraun/gofer/components/tooltip"
)

templ MailList(accounts []models.Account, emails []models.Email, activeFolder string, selectedEmail *models.Email, totalCount int, scrollCount int, windowStart int, width string, senderDisplayMode string, viewMode string, navigationMode string, filters models.EmailFilters) {
	<div id="mail-list" class="w-full lg:flex flex-col border-r border-border bg-card h-full overflow-hidden" style={ "width:" + mailListWidthCSS(width) } data-mail-list-view={ mailListViewMode(viewMode) } data-mail-navigation-mode={ mailListNavigationMode(navigationMode) }>
		@MailListHeader(activeFolder, totalCount)
		@MailListToolbar(accounts, activeFolder, mailListViewMode(viewMode), filters)
		@MailFilterAdvancedDialog(accounts)
		@MailCardLayoutDialog()
		<hr class="divider-etched"/>
		<div class="relative min-h-0 flex-1 overflow-hidden" data-mail-list-body>
			@MailListEmails(accounts, emails, activeFolder, selectedEmail, totalCount, scrollCount, windowStart, senderDisplayMode, mailListViewMode(viewMode), mailListNavigationMode(navigationMode))
		</div>
		if mailListNavigationMode(navigationMode) == "pagination" && scrollCount >= 0 {
			@MailListPagination(scrollCount, windowStart, len(emails), mailListPaginationPageSize())
		}
	</div>
}

templ MailListHeader(activeFolder string, totalCount int) {
	<div class="mail-list-header px-4 py-4 space-y-3">
		<div class="mail-list-title-row flex items-center justify-between">
			<div class="mail-list-title flex items-center gap-2 min-w-0">
				<h2 id="mail-folder-name" class="text-lg font-bold tracking-tight" style="font-family: var(--font-serif)">{ folderDisplayName(activeFolder) }</h2>
				if totalCount >= 0 {
					<span id="mail-folder-count" class="inline-flex h-5 min-w-10 items-center justify-center rounded-full bg-muted px-2 text-xs font-medium text-muted-foreground shadow-[0_1px_2px_rgba(0,0,0,0.06)]">{ fmt.Sprintf("%d", totalCount) }</span>
				} else {
					<span id="mail-folder-count" class="inline-flex h-5 min-w-10 items-center justify-center rounded-full bg-muted px-2 text-xs font-medium text-muted-foreground shadow-[0_1px_2px_rgba(0,0,0,0.06)] animate-pulse"></span>
				}
			</div>
		</div>
		<div class="mail-list-search-section">
			<div class="mail-list-search-primary">
				<div class="mail-list-search-input-wrap relative groove rounded-lg min-w-0">
					@icon.Search(icon.Props{Class: "absolute left-2.5 top-1/2 -translate-y-1/2 size-3.5 text-muted-foreground"})
					<input
						type="text"
						name="q"
						placeholder="Search, or use from: subject: body: then Enter"
						class="h-9 w-full pl-8 pr-3 rounded-lg text-sm bg-background border border-border/50 outline-none focus:ring-2 focus:ring-ring"
						data-mail-search-input
						autocomplete="off"
					/>
				</div>
				<div class="mail-list-search-actions">
					@MailQuickFilterDropdown()
					<button type="button" data-mail-advanced-filter-open class="mail-list-advanced-filter-button inline-flex h-9 shrink-0 items-center gap-1.5 rounded-lg border border-border bg-card px-2.5 text-xs font-semibold text-foreground hover:bg-accent">
						<span>Advanced filters</span>
						@icon.SlidersHorizontal(icon.Props{Class: "size-3.5"})
					</button>
				</div>
			</div>
			<div data-mail-active-filter-pills class="mail-active-filter-strip hidden" aria-label="Active filters"></div>
		</div>
	</div>
}

templ MailQuickFilterDropdown() {
	@dropdown.Dropdown() {
		@dropdown.Trigger() {
			<button type="button" aria-label="Filter messages" data-mail-filter-button class="mail-list-quick-filter-button relative inline-flex h-9 min-w-9 shrink-0 items-center justify-center rounded-lg border border-border bg-card px-2.5 text-foreground hover:bg-accent data-[active=true]:bg-accent data-[active=true]:text-foreground">
				@icon.ListFilter(icon.Props{Class: "size-3.5"})
				<span data-mail-filter-count class="hidden absolute -right-1 -top-1 min-w-4 h-4 rounded-full bg-primary px-1 text-[10px] leading-4 text-primary-foreground font-semibold"></span>
			</button>
		}
		@dropdown.Content(dropdown.ContentProps{Placement: dropdown.PlacementBottomEnd, Class: "w-64 normal-case tracking-normal p-2"}) {
			<form data-mail-filter-form class="space-y-2 pb-2">
				<div class="flex items-center justify-between gap-2 px-2 py-1.5">
					<div class="text-xs font-semibold text-muted-foreground">Quick filters</div>
					<button type="button" data-mail-filter-clear class="text-[11px] font-medium text-muted-foreground hover:text-foreground">Clear</button>
				</div>
				<div class="grid gap-2 px-2">
					<div class="space-y-1">
						<div class="text-[11px] font-medium text-muted-foreground">Status</div>
						@MailFilterTriState("status", "unread", "Unread", "read", "Read")
					</div>
					<div class="space-y-1">
						<div class="text-[11px] font-medium text-muted-foreground">Attachments</div>
						@MailFilterTriState("attachments", "no", "No", "yes", "Yes")
					</div>
					<div class="space-y-1">
						<div class="text-[11px] font-medium text-muted-foreground">Tags</div>
						@MailFilterTriState("tags", "no", "No", "yes", "Yes")
					</div>
					<div class="space-y-1">
						<div class="text-[11px] font-medium text-muted-foreground">Threads</div>
						@MailFilterTriState("threads", "no", "No", "yes", "Yes")
					</div>
					<div class="pt-0.5 text-center">
						<div class="flex flex-col items-center gap-1 text-[11px] font-medium text-muted-foreground">
							<div class="w-full truncate">Starred</div>
							@switchcomp.Switch(switchcomp.Props{Name: "starred", Value: "1", Class: "h-4 w-8 after:h-3 after:w-3 peer-checked:after:translate-x-4", Attributes: templ.Attributes{"data-mail-filter-input": ""}})
						</div>
					</div>
				</div>
			</form>
		}
	}
}

templ MailFilterTriState(name string, leftValue string, leftLabel string, rightValue string, rightLabel string) {
	<div class="mail-filter-tristate relative inline-grid h-7 w-full grid-cols-3 overflow-hidden border border-border bg-background p-0.5 text-[11px]" data-mail-tristate={ name } data-mail-tristate-value="">
		<div class="mail-filter-tristate-indicator" data-mail-tristate-indicator></div>
		<button type="button" data-mail-tristate-option={ leftValue } class="relative z-10 px-1.5 text-muted-foreground hover:text-foreground">{ leftLabel }</button>
		<button type="button" data-mail-tristate-option="" class="relative z-10 px-1.5 text-foreground">Any</button>
		<button type="button" data-mail-tristate-option={ rightValue } class="relative z-10 px-1.5 text-muted-foreground hover:text-foreground">{ rightLabel }</button>
	</div>
}

func mailSortLabel(filters models.EmailFilters) string {
	switch filters.SortBy {
	case "sender":
		return "Sender"
	case "subject":
		return "Subject"
	default:
		return "Date"
	}
}

templ MailListToolbar(accounts []models.Account, activeFolder string, viewMode string, filters models.EmailFilters) {
	<div class="mail-list-toolbar flex items-center gap-1 px-4 py-1.5">
		<div class="relative inline-flex h-7 rounded-lg border border-border bg-background p-0.5 gap-0.5" data-mail-list-view-toggle>
			<div
				data-mail-list-view-indicator
				class="absolute top-0.5 bottom-0.5 left-0.5 w-[calc(50%-2px)] rounded-md border border-border bg-card shadow-sm transition-transform duration-200 ease-out"
				style={ mailListViewIndicatorStyle(viewMode) }
			></div>
			<button
				type="button"
				data-mail-list-view-button="cards"
				aria-label="Cards view"
				class={
					"relative z-10 inline-flex h-6 items-center gap-1 px-2 rounded-md text-xs font-medium transition-colors duration-200",
					templ.KV("text-foreground", viewMode == "cards"),
					templ.KV("text-muted-foreground hover:text-foreground", viewMode != "cards"),
				}
			>
				@icon.LayoutList(icon.Props{Class: "size-3.5"})
				Cards
			</button>
			<button
				type="button"
				data-mail-list-view-button="table"
				aria-label="Table view"
				class={
					"relative z-10 inline-flex h-6 items-center gap-1 px-2 rounded-md text-xs font-medium transition-colors duration-200",
					templ.KV("text-foreground", viewMode == "table"),
					templ.KV("text-muted-foreground hover:text-foreground", viewMode != "table"),
				}
			>
				@icon.Table2(icon.Props{Class: "size-3.5"})
				Table
			</button>
		</div>
		<div class="mail-list-toolbar-spacer flex-1"></div>
		@dropdown.Dropdown() {
			@dropdown.Trigger() {
				<button type="button" class="inline-flex h-7 shrink-0 items-center gap-1.5 rounded-md px-2 text-xs font-medium text-muted-foreground hover:bg-accent hover:text-foreground" aria-label="Sort messages">
					@icon.ArrowUpDown(icon.Props{Class: "size-3.5"})
					<span class="hidden sm:inline">{ mailSortLabel(filters) }</span>
				</button>
			}
			@dropdown.Content(dropdown.ContentProps{Placement: dropdown.PlacementBottomEnd, Class: "w-64 normal-case tracking-normal p-3"}) {
				<form class="space-y-3" data-mail-sort-form>
					<div class="space-y-1 text-[11px] font-medium text-muted-foreground">
						<span>Order by</span>
						@selectbox.SelectBox() {
							@selectbox.Trigger(selectbox.TriggerProps{Name: "sort_by", Class: "h-8 bg-background text-xs", DisableClear: true}) {
								@selectbox.Value(selectbox.ValueProps{Placeholder: "Date"})
							}
							@selectbox.Content(selectbox.ContentProps{NoSearch: true, DisableExclusive: true}) {
								@selectbox.Item(selectbox.ItemProps{Value: "date", Selected: filters.SortBy == "" || filters.SortBy == "date"}) {
									Date
								}
								@selectbox.Item(selectbox.ItemProps{Value: "sender", Selected: filters.SortBy == "sender"}) {
									Sender
								}
								@selectbox.Item(selectbox.ItemProps{Value: "subject", Selected: filters.SortBy == "subject"}) {
									Subject
								}
							}
						}
					</div>
					<div class="space-y-1 text-[11px] font-medium text-muted-foreground">
						<span>Order</span>
						@selectbox.SelectBox() {
							@selectbox.Trigger(selectbox.TriggerProps{Name: "sort_order", Class: "h-8 bg-background text-xs", DisableClear: true}) {
								@selectbox.Value(selectbox.ValueProps{Placeholder: "Descending"})
							}
							@selectbox.Content(selectbox.ContentProps{NoSearch: true, DisableExclusive: true}) {
								@selectbox.Item(selectbox.ItemProps{Value: "desc", Selected: filters.SortOrder == "" || filters.SortOrder == "desc"}) {
									Descending
								}
								@selectbox.Item(selectbox.ItemProps{Value: "asc", Selected: filters.SortOrder == "asc"}) {
									Ascending
								}
							}
						}
					</div>
					<button type="submit" class="inline-flex h-8 w-full items-center justify-center rounded-md bg-primary px-3 text-xs font-semibold text-primary-foreground hover:bg-primary/90">Apply sort</button>
				</form>
			}
		}
		<button type="button" data-mail-selection-clear class="hidden h-7 items-center rounded-md px-2 text-xs font-semibold text-muted-foreground hover:bg-accent hover:text-foreground">
			<span data-mail-selection-summary>0 selected</span>
			<span class="ml-1 text-[10px]">Clear</span>
		</button>
		@tooltip.Tooltip() {
			@tooltip.Trigger() {
				@button.Button(button.Props{
					Variant:    button.VariantGhost,
					Size:       button.SizeIcon,
					Class:      "h-7 w-7",
					Disabled:   true,
					Attributes: templ.Attributes{"data-mail-selection-action": "archive", "aria-label": "Archive selected messages"},
				}) {
					@icon.Archive(icon.Props{Class: "size-3.5"})
				}
			}
			@tooltip.Content(tooltip.ContentProps{
				Position:  tooltip.PositionBottom,
				ShowArrow: true,
			}) {
				Archive
			}
		}
		@tooltip.Tooltip() {
			@tooltip.Trigger() {
				@button.Button(button.Props{
					Variant:  button.VariantGhost,
					Size:     button.SizeIcon,
					Class:    mailDeleteActionClass("h-7 w-7", "", mailFolderIDIsTrash(activeFolder, accounts)),
					Disabled: true,
					Attributes: templ.Attributes{
						"data-mail-selection-action": "delete",
						"data-mail-delete-permanent": fmt.Sprintf("%t", mailFolderIDIsTrash(activeFolder, accounts)),
						"aria-label":                 mailDeleteSelectionLabel(mailFolderIDIsTrash(activeFolder, accounts)),
					},
				}) {
					@icon.Trash2(icon.Props{Class: "size-3.5"})
				}
			}
			@tooltip.Content(tooltip.ContentProps{
				Position:  tooltip.PositionBottom,
				ShowArrow: true,
			}) {
				<span data-mail-delete-tooltip>
					if mailFolderIDIsTrash(activeFolder, accounts) {
						Permanently delete
					} else {
						Delete
					}
				</span>
			}
		}
		@tooltip.Tooltip() {
			@tooltip.Trigger() {
				@button.Button(button.Props{
					Variant:    button.VariantGhost,
					Size:       button.SizeIcon,
					Class:      "h-7 w-7",
					Disabled:   true,
					Attributes: templ.Attributes{"data-mail-selection-action": "read", "aria-label": "Mark selected messages as read"},
				}) {
					@icon.MailOpen(icon.Props{Class: "size-3.5"})
				}
			}
			@tooltip.Content(tooltip.ContentProps{
				Position:  tooltip.PositionBottom,
				ShowArrow: true,
			}) {
				Mark as read
			}
		}
		<div class="h-5 w-px bg-border/70 mx-1"></div>
		@MailListColumnSelector()
		@dropdown.Dropdown() {
			@dropdown.Trigger() {
				@button.Button(button.Props{
					Variant: button.VariantGhost,
					Size:    button.SizeIcon,
					Class:   "h-7 w-7",
				}) {
					@icon.EllipsisVertical(icon.Props{Class: "size-3.5"})
				}
			}
			@dropdown.Content() {
				@dropdown.Item(dropdown.ItemProps{Attributes: templ.Attributes{"data-mail-selection-action": "label"}}) {
					<span class="flex items-center gap-2">
						@icon.Tag(icon.Props{Class: "size-4"})
						Add label
					</span>
				}
				@dropdown.Item(dropdown.ItemProps{Attributes: templ.Attributes{"data-mail-selection-action": "unlabel"}}) {
					<span class="flex items-center gap-2">
						@icon.X(icon.Props{Class: "size-4"})
						Remove label
					</span>
				}
				@dropdown.Item(dropdown.ItemProps{Attributes: templ.Attributes{"data-mail-selection-action": "star"}}) {
					<span class="flex items-center gap-2">
						@icon.Star(icon.Props{Class: "size-4"})
						Star selected
					</span>
				}
				@dropdown.Separator()
				if mailFolderIDIsSpam(activeFolder, accounts) {
					@dropdown.Item(dropdown.ItemProps{Attributes: templ.Attributes{"data-mail-selection-action": "not-spam"}}) {
						<span class="flex items-center gap-2 font-medium text-emerald-700 dark:text-emerald-300">
							@icon.ShieldCheck(icon.Props{Class: "size-4"})
							Not spam
						</span>
					}
				} else {
					@dropdown.Item(dropdown.ItemProps{Attributes: templ.Attributes{"data-mail-selection-action": "spam"}}) {
						<span class="flex items-center gap-2">
							@icon.ShieldAlert(icon.Props{Class: "size-4"})
							Report spam
						</span>
					}
				}
			}
		}
	</div>
}

templ MailFilterAdvancedDialog(accounts []models.Account) {
	@dialog.Dialog(dialog.Props{ID: "mail-advanced-filter-dialog"}) {
		@dialog.Content(dialog.ContentProps{Class: "max-h-[calc(100vh-2rem)] overflow-y-auto sm:h-[26rem] sm:max-w-3xl sm:[&_[data-tui-dialog-panel]]:h-full sm:[&_[data-tui-dialog-panel]]:grid-rows-[auto_minmax(0,1fr)]"}) {
			@dialog.Header() {
				@dialog.Title() { Advanced filters }
				@dialog.Description() { Narrow the message list with any combination of filters. }
			}
			<form data-mail-advanced-filter-form class="flex min-h-0 flex-col gap-3">
				<div class="grid items-start gap-3 sm:grid-cols-[10rem_minmax(0,1fr)]">
					<nav class="flex gap-1 overflow-x-auto rounded-lg border border-border bg-muted/25 p-1.5 sm:flex-col sm:overflow-visible" aria-label="Advanced filter categories">
						@MailFilterCategoryButton("calendar", "Date range", true)
						@MailFilterCategoryButton("audience", "People", false)
						@MailFilterCategoryButton("content", "Content", false)
						@MailFilterCategoryButton("files", "Files", false)
						@MailFilterCategoryButton("status", "Status", false)
					</nav>
					<div data-mail-filter-panel-box class="rounded-lg border border-border bg-background/35 p-4 transition-[height] duration-200 ease-out">
						<section data-mail-filter-panel="calendar" class="space-y-3">
							<div>
								<h3 class="text-sm font-semibold text-foreground">Date range</h3>
								<p class="mt-0.5 text-xs text-muted-foreground">Limit results by message date.</p>
							</div>
							<div class="grid grid-cols-2 gap-3">
								<div class="space-y-1.5 text-xs font-medium text-muted-foreground">
									After
									@MailFilterCalendarField("after_date", "mail-filter-after-calendar", "Any date")
								</div>
								<div class="space-y-1.5 text-xs font-medium text-muted-foreground">
									Before
									@MailFilterCalendarField("before_date", "mail-filter-before-calendar", "Any date")
								</div>
							</div>
						</section>
						<section data-mail-filter-panel="audience" class="hidden space-y-3">
							<div>
								<h3 class="text-sm font-semibold text-foreground">People and accounts</h3>
								<p class="mt-0.5 text-xs text-muted-foreground">Choose an account, sender, or recipient.</p>
							</div>
							<div class="grid gap-3 sm:grid-cols-3">
								if len(accounts) > 0 {
									<label class="space-y-1.5 text-xs font-medium text-muted-foreground">
										Account
										@selectbox.SelectBox() {
											@selectbox.Trigger(selectbox.TriggerProps{Name: "account_id", Class: "h-8", Attributes: templ.Attributes{"data-mail-advanced-filter-input": ""}}) {
												@selectbox.Value(selectbox.ValueProps{Placeholder: "Any account"})
											}
											@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
												for _, account := range accounts {
													@selectbox.Item(selectbox.ItemProps{Value: account.ID}) { { account.Email } }
												}
											}
										}
									</label>
								}
								<label class="space-y-1.5 text-xs font-medium text-muted-foreground">
									From
									@input.Input(input.Props{Name: "from", Placeholder: "name or email", Class: "h-8", Attributes: templ.Attributes{"data-mail-advanced-filter-input": ""}})
								</label>
								<label class="space-y-1.5 text-xs font-medium text-muted-foreground">
									From domain
									@input.Input(input.Props{Name: "from_domain", Placeholder: "example.com", Class: "h-8", Attributes: templ.Attributes{"data-mail-advanced-filter-input": ""}})
								</label>
								<label class="space-y-1.5 text-xs font-medium text-muted-foreground">
									Recipients
									@input.Input(input.Props{Name: "to", Placeholder: "name or email", Class: "h-8", Attributes: templ.Attributes{"data-mail-advanced-filter-input": ""}})
								</label>
								<label class="space-y-1.5 text-xs font-medium text-muted-foreground">
									Recipient type
									@selectbox.SelectBox() {
										@selectbox.Trigger(selectbox.TriggerProps{Name: "recipient_type", Class: "h-8", Attributes: templ.Attributes{"data-mail-advanced-filter-input": ""}}) {
											@selectbox.Value(selectbox.ValueProps{Placeholder: "Any type"})
										}
										@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
											@selectbox.Item(selectbox.ItemProps{Value: "to"}) { To }
											@selectbox.Item(selectbox.ItemProps{Value: "cc"}) { CC }
											@selectbox.Item(selectbox.ItemProps{Value: "bcc"}) { BCC }
										}
									}
								</label>
								<label class="space-y-1.5 text-xs font-medium text-muted-foreground">
									Recipient domain
									@input.Input(input.Props{Name: "recipient_domain", Placeholder: "example.com", Class: "h-8", Attributes: templ.Attributes{"data-mail-advanced-filter-input": ""}})
								</label>
							</div>
						</section>
						<section data-mail-filter-panel="content" class="hidden space-y-3">
							<div>
								<h3 class="text-sm font-semibold text-foreground">Message content</h3>
								<p class="mt-0.5 text-xs text-muted-foreground">Search specific message fields.</p>
							</div>
							<div class="grid gap-3 sm:grid-cols-2">
								<label class="space-y-1.5 text-xs font-medium text-muted-foreground">
									Subject contains
									@input.Input(input.Props{Name: "subject", Placeholder: "invoice, project, receipt...", Class: "h-8", Attributes: templ.Attributes{"data-mail-advanced-filter-input": ""}})
								</label>
								<label class="space-y-1.5 text-xs font-medium text-muted-foreground">
									Body contains
									@input.Input(input.Props{Name: "body", Placeholder: "text in message body", Class: "h-8", Attributes: templ.Attributes{"data-mail-advanced-filter-input": ""}})
								</label>
								<label class="space-y-1.5 text-xs font-medium text-muted-foreground">
									Tag
									@input.Input(input.Props{Name: "tag", Placeholder: "work, invoices...", Class: "h-8", Attributes: templ.Attributes{"data-mail-advanced-filter-input": ""}})
								</label>
							</div>
						</section>
						<section data-mail-filter-panel="files" class="hidden space-y-3">
							<div>
								<h3 class="text-sm font-semibold text-foreground">Files and size</h3>
								<p class="mt-0.5 text-xs text-muted-foreground">Filter by attachment details or total message size.</p>
							</div>
							<div class="grid gap-3 sm:grid-cols-2">
								<label class="space-y-1.5 text-xs font-medium text-muted-foreground">
									Attachment filename
									@input.Input(input.Props{Name: "attachment", Placeholder: "receipt.pdf", Class: "h-8", Attributes: templ.Attributes{"data-mail-advanced-filter-input": ""}})
								</label>
								<label class="space-y-1.5 text-xs font-medium text-muted-foreground">
									Attachment type
									@selectbox.SelectBox() {
										@selectbox.Trigger(selectbox.TriggerProps{Name: "attachment_type", Class: "h-8", Attributes: templ.Attributes{"data-mail-advanced-filter-input": ""}}) {
											@selectbox.Value(selectbox.ValueProps{Placeholder: "Any type"})
										}
										@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
											@selectbox.Item(selectbox.ItemProps{Value: "pdf"}) { PDF }
											@selectbox.Item(selectbox.ItemProps{Value: "image"}) { Images }
											@selectbox.Item(selectbox.ItemProps{Value: "document"}) { Documents }
											@selectbox.Item(selectbox.ItemProps{Value: "spreadsheet"}) { Spreadsheets }
											@selectbox.Item(selectbox.ItemProps{Value: "presentation"}) { Presentations }
											@selectbox.Item(selectbox.ItemProps{Value: "archive"}) { Archives }
											@selectbox.Item(selectbox.ItemProps{Value: "audio"}) { Audio }
											@selectbox.Item(selectbox.ItemProps{Value: "video"}) { Video }
											@selectbox.Item(selectbox.ItemProps{Value: "custom"}) { Custom extension }
										}
									}
								</label>
								<label data-mail-attachment-extension-field class="hidden space-y-1.5 text-xs font-medium text-muted-foreground sm:col-span-2">
									Custom extension
									@input.Input(input.Props{Name: "attachment_extension", Placeholder: "e.g. eml", Class: "h-8", Attributes: templ.Attributes{"data-mail-advanced-filter-input": "", "maxlength": "16", "pattern": "\\.?[A-Za-z0-9]+", "title": "Enter an extension such as eml or .eml"}})
								</label>
								<label class="space-y-1.5 text-xs font-medium text-muted-foreground">
									Minimum message size (MB)
									@input.Input(input.Props{Name: "min_size_mb", Type: input.TypeNumber, Placeholder: "0 MB", Class: "h-8", Attributes: templ.Attributes{"data-mail-advanced-filter-input": "", "min": "0", "step": "0.1"}})
								</label>
								<label class="space-y-1.5 text-xs font-medium text-muted-foreground">
									Maximum message size (MB)
									@input.Input(input.Props{Name: "max_size_mb", Type: input.TypeNumber, Placeholder: "Any size", Class: "h-8", Attributes: templ.Attributes{"data-mail-advanced-filter-input": "", "min": "0", "step": "0.1"}})
								</label>
							</div>
						</section>
						<section data-mail-filter-panel="status" class="hidden space-y-3">
							<div>
								<h3 class="text-sm font-semibold text-foreground">Message status</h3>
								<p class="mt-0.5 text-xs text-muted-foreground">Match message state and conversation type.</p>
							</div>
							<div class="grid grid-cols-2 gap-3">
								<div class="space-y-1">
									<div class="text-[11px] font-medium text-muted-foreground">Read status</div>
									@MailFilterTriState("status", "unread", "Unread", "read", "Read")
								</div>
								<div class="space-y-1">
									<div class="text-[11px] font-medium text-muted-foreground">Attachments</div>
									@MailFilterTriState("attachments", "no", "No", "yes", "Yes")
								</div>
								<div class="space-y-1">
									<div class="text-[11px] font-medium text-muted-foreground">Tags</div>
									@MailFilterTriState("tags", "no", "No", "yes", "Yes")
								</div>
								<div class="space-y-1">
									<div class="text-[11px] font-medium text-muted-foreground">Threads</div>
									@MailFilterTriState("threads", "no", "No", "yes", "Yes")
								</div>
							</div>
						</section>
					</div>
				</div>
				<div class="mt-auto flex items-center justify-between gap-2 border-t border-border pt-3">
					<button type="button" data-mail-advanced-filter-clear class="h-8 rounded-md px-2 text-xs font-medium text-muted-foreground hover:bg-accent hover:text-foreground">Clear all</button>
					<div class="flex items-center gap-2">
						@dialog.Close(dialog.CloseProps{For: "mail-advanced-filter-dialog"}) {
							<button type="button" class="h-8 rounded-md border border-border px-3 text-xs font-medium hover:bg-accent">Cancel</button>
						}
						<button type="submit" class="inline-flex h-8 items-center gap-1.5 rounded-md bg-primary px-3 text-xs font-semibold text-primary-foreground hover:bg-primary/90">
							<span>Apply</span>
							<span data-mail-advanced-filter-count class="hidden min-w-4 rounded-full bg-primary-foreground/15 px-1.5 py-0.5 text-center text-[10px] leading-none">0</span>
						</button>
					</div>
				</div>
			</form>
		}
	}
}

templ MailFilterCategoryButton(value string, label string, active bool) {
	<button
		type="button"
		data-mail-filter-panel-button={ value }
		data-active={ fmt.Sprintf("%t", active) }
		aria-selected={ fmt.Sprintf("%t", active) }
		class="shrink-0 rounded-md px-2.5 py-2 text-left text-sm font-medium text-muted-foreground transition-colors hover:bg-background/70 hover:text-foreground data-[active=true]:bg-background data-[active=true]:text-foreground data-[active=true]:shadow-sm data-[active=true]:ring-1 data-[active=true]:ring-border sm:w-full"
	>
		{ label }
	</button>
}

templ MailFilterCalendarField(name string, id string, placeholder string) {
	@dropdown.Dropdown() {
		@dropdown.Trigger() {
			<button type="button" class="flex h-8 w-full items-center justify-between rounded-md border border-input bg-input/30 px-3 text-sm font-normal text-foreground shadow-xs hover:bg-accent/50">
				<span data-mail-date-display={ name } class="truncate text-muted-foreground">{ placeholder }</span>
				@icon.Calendar(icon.Props{Class: "size-4 text-muted-foreground"})
			</button>
		}
		@dropdown.Content(dropdown.ContentProps{Placement: dropdown.PlacementBottomStart, Class: "w-auto p-3"}) {
			@calendar.Calendar(calendar.Props{ID: id, Name: name, Class: "[--cell-size:1.9rem]", HideHiddenInput: false})
		}
	}
}

templ MailListEmails(accounts []models.Account, emails []models.Email, folderID string, selectedEmail *models.Email, totalCount int, scrollCount int, windowStart int, senderDisplayMode string, viewMode string, navigationMode string) {
	<div
		id="mail-list-scroll"
		class="h-full overflow-y-auto px-2 py-2"
		data-hydrate-dropin
		data-total-count={ fmt.Sprintf("%d", scrollCount) }
		data-display-total-count={ fmt.Sprintf("%d", totalCount) }
		data-folder-id={ folderID }
		data-view-mode={ mailListViewMode(viewMode) }
		data-navigation-mode={ mailListNavigationMode(navigationMode) }
		data-window-start={ fmt.Sprintf("%d", windowStart) }
		data-page-size={ fmt.Sprintf("%d", mailListPaginationPageSize()) }
		data-account-marker-style={ accountMarkerStyle(accounts) }
		data-load-folder?={ totalCount < 0 || scrollCount < 0 }
	>
		if totalCount < 0 || scrollCount < 0 {
			<div class="flex h-full items-center justify-center">
				<div class="flex items-center gap-2 text-sm text-muted-foreground">
					<div class="size-4 border-2 border-muted-foreground/30 border-t-muted-foreground rounded-full animate-spin"></div>
					<span>Loading content...</span>
				</div>
			</div>
		} else if mailListViewMode(viewMode) == "table" {
			@MailListTableHeader(accountMarkerStyle(accounts))
		}
		if scrollCount >= 0 {
			for i, email := range emails {
				@MailListItem(accounts, email, windowStart+i, selectedEmail, senderDisplayMode, mailListViewMode(viewMode))
			}
			if len(emails) == 0 {
				@MailListEmpty()
			}
		}
	</div>
}

templ MailListPagination(totalCount int, windowStart int, itemCount int, pageSize int) {
	<div class="border-t border-border/70 bg-card/95 px-3 py-2" data-mail-pagination data-page-size={ fmt.Sprintf("%d", pageSize) }>
		<div class="flex items-center justify-between gap-2">
			<div class="min-w-0 text-[11px] font-medium text-muted-foreground" data-mail-pagination-summary>{ mailListPaginationRangeLabel(windowStart, itemCount, totalCount) }</div>
			<div class="flex items-center gap-1.5">
				<button type="button" class="inline-flex h-7 items-center gap-1 rounded-md border border-border px-2 text-[11px] font-semibold text-foreground hover:bg-accent disabled:cursor-not-allowed disabled:opacity-45" data-mail-page-prev disabled?={ windowStart <= 0 }>
					@icon.ChevronLeft(icon.Props{Class: "size-3"})
					Prev
				</button>
				<span class="min-w-16 text-center text-[11px] font-medium text-muted-foreground" data-mail-pagination-page>{ fmt.Sprintf("%d / %d", mailListPaginationPage(windowStart, pageSize), mailListPaginationTotalPages(totalCount, pageSize)) }</span>
				<button type="button" class="inline-flex h-7 items-center gap-1 rounded-md border border-border px-2 text-[11px] font-semibold text-foreground hover:bg-accent disabled:cursor-not-allowed disabled:opacity-45" data-mail-page-next disabled?={ windowStart+itemCount >= totalCount || itemCount == 0 }>
					Next
					@icon.ChevronRight(icon.Props{Class: "size-3"})
				</button>
			</div>
		</div>
	</div>
}

templ MailListItem(accounts []models.Account, email models.Email, position int, selectedEmail *models.Email, senderDisplayMode string, viewMode string) {
	if mailListViewMode(viewMode) == "table" {
		@MailListTableItem(email, position, selectedEmail, senderDisplayMode)
	} else {
		@MailListCardItem(accounts, email, position, selectedEmail, senderDisplayMode)
	}
}

templ MailListTableHeader(markerStyle string) {
	<div class="mail-list-table-header mail-list-table-grid grid items-center gap-3 px-3 py-1.5 text-[10px] font-semibold uppercase tracking-wider text-muted-foreground bg-card/95 border-b border-border/70 sticky top-0 z-20 backdrop-blur-sm">
		<div class="mail-list-table-heading flex items-center justify-center" data-mail-table-column="0" data-mail-table-column-id="accountMarker" data-mail-table-cell="accountMarker" title="Account Marker">
			<span class="account-color-marker size-2.5" style={ markerStyle }></span><span class="mail-list-column-separator"></span>
		</div>
		<div class="mail-list-table-heading text-center" data-mail-table-column="1" data-mail-table-column-id="starred" data-mail-table-cell="starred" title="Starred">@icon.Star(icon.Props{Class: "size-3 mx-auto"})
<span class="mail-list-column-separator"></span></div>
		<div class="mail-list-table-heading text-center" data-mail-table-column="2" data-mail-table-column-id="attachment" data-mail-table-cell="attachment" title="Attachment">@icon.Paperclip(icon.Props{Class: "size-3 mx-auto"})
<span class="mail-list-column-separator"></span></div>
		<div class="mail-list-table-heading flex items-center justify-start" data-mail-table-column="3" data-mail-table-column-id="thread" data-mail-table-cell="thread" title="Thread">
			@icon.MessagesSquare(icon.Props{Class: "size-3"})
			<span class="mail-list-column-separator"></span>
		</div>
		<div class="mail-list-table-heading" data-mail-table-column="4" data-mail-table-column-id="from" data-mail-table-cell="from">From<span class="mail-list-column-resize" data-mail-table-resize="4"></span></div>
		<div class="mail-list-table-heading" data-mail-table-column="5" data-mail-table-column-id="to" data-mail-table-cell="to">To<span class="mail-list-column-resize" data-mail-table-resize="5"></span></div>
		<div class="mail-list-table-heading" data-mail-table-column="6" data-mail-table-column-id="subject" data-mail-table-cell="subject">Subject<span class="mail-list-column-resize" data-mail-table-resize="6"></span></div>
		<div class="mail-list-table-heading min-w-12 text-right" data-mail-table-column="7" data-mail-table-column-id="date" data-mail-table-cell="date">Date</div>
	</div>
}

templ MailListColumnSelector() {
	<div data-mail-card-layout-trigger-wrapper>
		@tooltip.Tooltip() {
			@tooltip.Trigger() {
				@button.Button(button.Props{Variant: button.VariantGhost, Size: button.SizeIcon, Class: "h-7 w-7", Attributes: templ.Attributes{"aria-label": "Customize card layout", "data-mail-card-layout-dialog-open": ""}}) {
					@icon.LayoutTemplate(icon.Props{Class: "size-3.5"})
				}
			}
			@tooltip.Content(tooltip.ContentProps{Position: tooltip.PositionBottom, ShowArrow: true}) {
				Card layout
			}
		}
	</div>
	<div data-mail-table-column-trigger-wrapper>
		@dropdown.Dropdown() {
			@dropdown.Trigger(dropdown.TriggerProps{Attributes: templ.Attributes{"data-mail-list-display-menu-button": ""}}) {
				@button.Button(button.Props{Variant: button.VariantGhost, Size: button.SizeIcon, Class: "h-7 w-7", Attributes: templ.Attributes{"aria-label": "Customize table columns"}}) {
					@icon.Settings(icon.Props{Class: "size-3.5"})
				}
			}
			@dropdown.Content(dropdown.ContentProps{Placement: dropdown.PlacementBottomEnd, Class: "normal-case tracking-normal", Attributes: templ.Attributes{"data-mail-list-display-menu": ""}}) {
				<div data-mail-table-column-menu>
					@dropdown.Label(dropdown.LabelProps{Class: "text-xs text-muted-foreground"}) {
						Columns
					}
					@MailListColumnOption("accountMarker", "Account Marker")
					@MailListColumnOption("starred", "Starred")
					@MailListColumnOption("attachment", "Attachment")
					@MailListColumnOption("thread", "Thread")
					@MailListColumnOption("from", "From")
					@MailListColumnOption("to", "To")
					@MailListColumnOption("subject", "Subject")
					@MailListColumnOption("date", "Date")
				</div>
			}
		}
	</div>
}

templ MailListColumnOption(value string, label string) {
	@dropdown.Item(dropdown.ItemProps{PreventClose: true, Class: "gap-2", Attributes: templ.Attributes{"data-mail-table-column-item": value}}) {
		<span class="w-4 shrink-0 text-primary opacity-0" data-mail-table-column-check={ value }>
			@icon.Check(icon.Props{Class: "size-4"})
		</span>
		<span class="flex-1 text-left">{ label }</span>
	}
}

templ MailCardLayoutDialog() {
	@dialog.Dialog(dialog.Props{ID: "mail-card-layout-dialog"}) {
		@dialog.Content(dialog.ContentProps{Class: "sm:max-w-5xl"}) {
			@dialog.Header() {
				@dialog.Title() {
					Card layout
				}
			}
			<div class="mail-card-layout-dialog-grid grid gap-3">
				<div class="space-y-2 min-w-0">
					<div class="flex items-center justify-between gap-2">
						<div class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Card</div>
						<div class="flex items-center gap-2">
							<button type="button" data-mail-card-layout-reset class="inline-flex h-7 items-center gap-1.5 rounded-md border border-border bg-card px-2 text-[11px] font-semibold text-muted-foreground hover:bg-accent hover:text-foreground">
								@icon.RotateCcw(icon.Props{Class: "size-3"})
								Reset layout
							</button>
							<div class="text-[11px] font-medium text-muted-foreground tabular-nums" data-mail-card-layout-limit></div>
						</div>
					</div>
					<div class="mail-card-layout-preview-shell rounded-lg border border-border bg-background/45 p-3">
						<div class="mail-card-layout-preview-card mail-list-card rounded-lg border border-border bg-card px-3.5 py-2.5 shadow-sm" data-mail-card-layout-preview data-mail-card-layout-scope>
							<div class="mail-list-card-zone mail-list-card-zone-rail-top" data-mail-card-zone="railTop" data-mail-card-layout-zone-items="railTop" data-mail-card-layout-dropzone="railTop">
								<span data-mail-card-field="avatar" class="inline-flex size-6 items-center justify-center rounded-full bg-primary/15 text-[10px] font-semibold text-primary shadow-[0_1px_3px_rgba(0,0,0,0.15)]">CB</span>
							</div>
							<div class="mail-list-card-zone mail-list-card-zone-rail-middle" data-mail-card-zone="railMiddle" data-mail-card-layout-zone-items="railMiddle" data-mail-card-layout-dropzone="railMiddle">
								<span data-mail-card-field="accountMarker" class="inline-flex items-center justify-center shrink-0">
									<span class="account-color-marker size-2.5 shrink-0 bg-primary"></span>
								</span>
							</div>
							<div class="mail-list-card-zone mail-list-card-zone-rail-bottom" data-mail-card-zone="railBottom" data-mail-card-layout-zone-items="railBottom" data-mail-card-layout-dropzone="railBottom">
								<span data-mail-card-field="thread" class="inline-flex items-center gap-0.5 text-[11px] text-muted-foreground">
									@icon.MessagesSquare(icon.Props{Class: "size-3"})
									3
								</span>
							</div>
							<div class="mail-list-card-zone mail-list-card-zone-header" data-mail-card-zone="header" data-mail-card-layout-zone-items="header" data-mail-card-layout-dropzone="header">
								<span data-mail-card-field="from" class="truncate text-sm font-semibold text-foreground">Cristian Braun</span>
								<span data-mail-card-field="date" class="text-xs font-medium tabular-nums text-primary">10:42</span>
								<span data-mail-card-field="account" class="mail-list-card-account inline-flex min-w-0 max-w-[42%] items-center gap-1 rounded-full border border-border/70 bg-background/40 px-1.5 py-0.5 text-[10px] font-medium text-muted-foreground">
									<span class="account-color-marker size-2 shrink-0 bg-primary"></span>
									<span class="truncate">Work</span>
								</span>
							</div>
							<div class="mail-list-card-zone mail-list-card-zone-meta" data-mail-card-zone="meta" data-mail-card-layout-zone-items="meta" data-mail-card-layout-dropzone="meta">
								<span data-mail-card-field="attachment">
									@icon.Paperclip(icon.Props{Class: "size-3 text-muted-foreground"})
								</span>
								<span data-mail-card-field="unread" class="inline-flex size-4 shrink-0 items-center justify-center">
									<span class="size-2 rounded-full bg-primary shadow-[0_0_6px_rgba(199,123,48,0.4)]"></span>
								</span>
							</div>
							<div class="mail-list-card-zone mail-list-card-zone-body" data-mail-card-zone="body" data-mail-card-layout-zone-items="body" data-mail-card-layout-dropzone="body">
								<p data-mail-card-field="subject" class="truncate text-[13px] font-medium text-foreground">Layout editor review</p>
								<p data-mail-card-field="to" class="truncate text-[11px] leading-snug text-muted-foreground">
									<span class="font-medium text-muted-foreground/80">To</span>
									Team
								</p>
							</div>
							<div class="mail-list-card-zone mail-list-card-zone-footer" data-mail-card-zone="footer" data-mail-card-layout-zone-items="footer" data-mail-card-layout-dropzone="footer">
								<p data-mail-card-field="preview" class="min-w-0 flex-1 truncate text-xs leading-relaxed text-muted-foreground">Preview text stays attached to the selected card section.</p>
								<span data-mail-card-field="labels" class="shrink-0 rounded bg-primary/10 px-1.5 py-0.5 text-[10px] font-medium text-primary shadow-[0_1px_2px_rgba(0,0,0,0.08)]">Design</span>
							</div>
							<div class="mail-list-card-zone mail-list-card-zone-status" data-mail-card-zone="status" data-mail-card-layout-zone-items="status" data-mail-card-layout-dropzone="status"></div>
							<div class="mail-list-card-zone mail-list-card-zone-corner" data-mail-card-zone="corner" data-mail-card-layout-zone-items="corner" data-mail-card-layout-dropzone="corner">
								<span data-mail-card-field="starred">
									@icon.Star(icon.Props{Class: "size-3.5 shrink-0 fill-amber-500 text-amber-500 drop-shadow-[0_1px_1px_rgba(180,120,0,0.4)]"})
								</span>
							</div>
							<div class="hidden" data-mail-card-zone="hidden"></div>
						</div>
					</div>
				</div>
				<div class="mail-card-layout-hidden-panel min-w-0 rounded-lg border border-border bg-background/45 p-2" data-mail-card-layout-dropzone="hidden">
					<div class="mb-1 flex items-center justify-between gap-2">
						<div class="flex min-w-0 items-center gap-1.5">
							<div class="truncate text-[11px] font-semibold uppercase tracking-wider text-muted-foreground">AVAILABLE FIELDS</div>
							@tooltip.Tooltip() {
								@tooltip.Trigger(tooltip.TriggerProps{Class: "inline-flex shrink-0"}) {
									<button type="button" class="mail-card-layout-help-trigger" aria-label="Available fields placement rules">
										@icon.CircleQuestionMark(icon.Props{Class: "size-3.5"})
									</button>
								}
								@tooltip.Content(tooltip.ContentProps{Position: tooltip.PositionTop, ShowArrow: true, Class: "mail-card-layout-help-tooltip"}) {
									<p><strong>Text fields</strong> can be placed only in the center rows: top, middle, and bottom.</p>
									<p><strong>Icon-only fields</strong> can be placed only in side slots: the three left rail spots and the right top, middle, and bottom areas.</p>
								}
							}
						</div>
						<div class="h-1.5 w-1.5 rounded-full bg-border"></div>
					</div>
					<div class="mail-card-layout-available-list min-h-10 rounded-md border border-dashed border-border/80 bg-card/70 p-1.5" data-mail-card-layout-zone-items="hidden"></div>
				</div>
			</div>
			@dialog.Footer() {
				@dialog.Close() {
					@button.Button(button.Props{Class: "h-8 px-3 text-xs"}) {
						Done
					}
				}
			}
		}
	}
}

templ MailListCardItem(accounts []models.Account, email models.Email, position int, selectedEmail *models.Email, senderDisplayMode string) {
	<div class="mail-list-item" data-email-id={ email.ID } data-position={ fmt.Sprintf("%d", position) } data-thread-id={ email.ThreadID } data-has-thread={ fmt.Sprintf("%t", email.ThreadCount > 1) }>
		<a
			href={ templ.URL(fmt.Sprintf("/?email=%s", email.ID)) }
			hx-get={ mailViewPartialURL(email.ID, email.FolderID, false) }
			hx-target="#mail-view"
			hx-swap="innerHTML"
			class={
				"mail-list-card px-3.5 py-2.5 rounded-lg cursor-pointer transition-all duration-200 group",
				templ.KV("envelope-active", selectedEmail != nil && selectedEmail.ID == email.ID),
				templ.KV("envelope", selectedEmail == nil || selectedEmail.ID != email.ID),
			}
			data-mail-card-layout-scope
		>
			<div class="mail-list-card-zone mail-list-card-zone-rail-top" data-mail-card-zone="railTop">
				<div data-mail-card-field="avatar">
					@ContactAvatar(email.From, "size-6 rounded-full text-[10px] font-semibold shadow-[0_1px_3px_rgba(0,0,0,0.15)]", contactAvatarListFallback(email.IsRead))
				</div>
			</div>
			<div class="mail-list-card-zone mail-list-card-zone-rail-middle" data-mail-card-zone="railMiddle">
				<span data-mail-card-field="accountMarker" class="inline-flex items-center justify-center shrink-0">
					<span class="account-color-marker size-2.5 shrink-0" style={ accountColorStyle(email.AccountColor) }></span>
				</span>
			</div>
			<div class="mail-list-card-zone mail-list-card-zone-rail-bottom" data-mail-card-zone="railBottom">
				if email.ThreadCount > 1 {
					<button type="button" data-thread-toggle={ email.ID } data-mail-card-field="thread" class="flex items-center gap-0.5 text-[11px] text-muted-foreground shrink-0 hover:text-foreground/70 transition-colors cursor-pointer">
						@icon.MessagesSquare(icon.Props{Class: "size-3"})
						{ fmt.Sprintf("%d", email.ThreadCount) }
						@icon.ChevronRight(icon.Props{Class: "size-3 transition-transform thread-toggle-chevron"})
					</button>
				} else {
					<span data-mail-card-field="thread" class="mail-list-card-empty-icon-slot" aria-hidden="true"></span>
				}
			</div>
			<div class="mail-list-card-zone mail-list-card-zone-header" data-mail-card-zone="header">
				<span
					class={
						"text-sm truncate",
						templ.KV("font-semibold text-foreground", !email.IsRead),
						templ.KV("text-foreground/70", email.IsRead),
					}
					data-mail-card-field="from"
				>{ senderDisplay(email.From, senderDisplayMode) }</span>
				<span
					class={
						"text-xs tabular-nums",
						templ.KV("text-primary font-medium", !email.IsRead),
						templ.KV("text-muted-foreground", email.IsRead),
					}
					data-mail-card-field="date"
				>{ email.Date }</span>
				<span data-mail-card-field="account" class="mail-list-card-account inline-flex min-w-0 max-w-[42%] items-center gap-1 rounded-full border border-border/70 bg-background/40 px-1.5 py-0.5 text-[10px] font-medium text-muted-foreground">
					<span class="account-color-marker size-2 shrink-0" style={ accountColorStyle(email.AccountColor) }></span>
					<span class="truncate">{ mailListAccountDisplay(accounts, email.AccountID) }</span>
				</span>
			</div>
			<div class="mail-list-card-zone mail-list-card-zone-meta" data-mail-card-zone="meta">
				if email.HasAttachment {
					<span data-mail-card-field="attachment">
						@icon.Paperclip(icon.Props{Class: "size-3 text-muted-foreground"})
					</span>
				} else {
					<span data-mail-card-field="attachment" class="mail-list-card-empty-icon-slot" aria-hidden="true"></span>
				}
				if !email.IsRead {
					<span data-mail-card-field="unread" class="inline-flex size-4 shrink-0 items-center justify-center">
						<span class="size-2 rounded-full bg-primary shadow-[0_0_6px_rgba(199,123,48,0.4)]"></span>
					</span>
				} else {
					<span data-mail-card-field="unread" class="mail-list-card-empty-icon-slot" aria-hidden="true"></span>
				}
			</div>
			<div class="mail-list-card-zone mail-list-card-zone-body" data-mail-card-zone="body">
				<p
					class={
						"text-[13px] truncate",
						templ.KV("font-medium text-foreground", !email.IsRead),
						templ.KV("text-foreground/60", email.IsRead),
					}
					data-mail-card-field="subject"
				>{ email.Subject }</p>
				if len(email.To) > 0 {
					<p data-mail-card-field="to" class="text-[11px] text-muted-foreground truncate leading-snug">
						<span class="font-medium text-muted-foreground/80">To</span>
						{ contactsDisplay(email.To, senderDisplayMode) }
					</p>
				}
			</div>
			<div class="mail-list-card-zone mail-list-card-zone-footer" data-mail-card-zone="footer">
				<p class="min-w-0 flex-1 text-xs text-muted-foreground truncate leading-relaxed" data-mail-card-field="preview">{ email.Preview }</p>
				if len(email.Labels) > 0 {
					for _, label := range email.Labels {
						<span class={ "text-[10px] px-1.5 py-0.5 rounded font-medium shrink-0 shadow-[0_1px_2px_rgba(0,0,0,0.08)]", label.Color } data-mail-card-field="labels">
							{ label.Name }
						</span>
					}
				}
			</div>
			<div class="mail-list-card-zone mail-list-card-zone-status" data-mail-card-zone="status"></div>
			<div class="mail-list-card-zone mail-list-card-zone-corner" data-mail-card-zone="corner">
				if email.IsStarred {
					<span data-mail-card-field="starred">
						@icon.Star(icon.Props{Class: "size-3.5 text-amber-500 fill-amber-500 shrink-0 drop-shadow-[0_1px_1px_rgba(180,120,0,0.4)]"})
					</span>
				} else {
					<button class="opacity-0 group-hover:opacity-100 transition-opacity star-btn shrink-0" data-email-id={ email.ID } data-mail-card-field="starred">
						@icon.Star(icon.Props{Class: "size-3.5 text-muted-foreground/30"})
					</button>
				}
			</div>
			<div class="hidden" data-mail-card-zone="hidden"></div>
		</a>
	</div>
}

templ MailListTableItem(email models.Email, position int, selectedEmail *models.Email, senderDisplayMode string) {
	<div class="mail-list-item mail-list-table-row" data-email-id={ email.ID } data-position={ fmt.Sprintf("%d", position) } data-thread-id={ email.ThreadID } data-has-thread={ fmt.Sprintf("%t", email.ThreadCount > 1) }>
		<a
			href={ templ.URL(fmt.Sprintf("/?email=%s", email.ID)) }
			hx-get={ mailViewPartialURL(email.ID, email.FolderID, false) }
			hx-target="#mail-view"
			hx-swap="innerHTML"
			class={
				"mail-list-table-grid grid items-center gap-3 px-3 py-1.5 rounded-md cursor-pointer transition-all duration-150 group text-xs",
				templ.KV("envelope-active", selectedEmail != nil && selectedEmail.ID == email.ID),
				templ.KV("envelope", selectedEmail == nil || selectedEmail.ID != email.ID),
			}
		>
			<div class="flex items-center justify-center" data-mail-table-cell="accountMarker">
				<span class="account-color-marker size-2.5 shrink-0" style={ accountColorStyle(email.AccountColor) }></span>
			</div>
			<div class="flex items-center justify-center text-muted-foreground" data-mail-table-cell="starred">
				if email.IsStarred {
					@icon.Star(icon.Props{Class: "size-3.5 text-amber-500 fill-amber-500"})
				} else {
					<button class="opacity-0 group-hover:opacity-100 transition-opacity star-btn" data-email-id={ email.ID }>
						@icon.Star(icon.Props{Class: "size-3.5 text-muted-foreground/30"})
					</button>
				}
			</div>
			<div class="flex items-center justify-center text-muted-foreground" data-mail-table-cell="attachment">
				if email.HasAttachment {
					@icon.Paperclip(icon.Props{Class: "size-3"})
				}
			</div>
			<div class="flex items-center justify-start min-w-0" data-mail-table-cell="thread">
				if email.ThreadCount > 1 {
					<button type="button" data-thread-toggle={ email.ID } class="flex items-center gap-0.5 text-[11px] text-muted-foreground shrink-0 hover:text-foreground/70 transition-colors cursor-pointer">
						@icon.MessagesSquare(icon.Props{Class: "size-3"})
						{ fmt.Sprintf("%d", email.ThreadCount) }
						@icon.ChevronRight(icon.Props{Class: "size-3 transition-transform thread-toggle-chevron"})
					</button>
				}
			</div>
			<div class="flex items-center min-w-0" data-mail-table-cell="from">
				<span
					class={
						"truncate",
						templ.KV("font-semibold text-foreground", !email.IsRead),
						templ.KV("text-foreground/70", email.IsRead),
					}
				>{ senderDisplay(email.From, senderDisplayMode) }</span>
			</div>
			<div class="flex items-center min-w-0" data-mail-table-cell="to">
				<span
					class={
						"truncate",
						templ.KV("font-medium text-foreground/80", !email.IsRead),
						templ.KV("text-foreground/55", email.IsRead),
					}
				>{ contactsDisplay(email.To, senderDisplayMode) }</span>
			</div>
			<div class="flex items-center gap-2 min-w-0" data-mail-table-cell="subject">
				<span
					class={
						"truncate",
						templ.KV("font-medium text-foreground", !email.IsRead),
						templ.KV("text-foreground/65", email.IsRead),
					}
				>{ email.Subject }</span>
				if len(email.Labels) > 0 {
					for _, label := range email.Labels {
						<span class={ "hidden xl:inline text-[10px] px-1.5 py-0.5 rounded font-medium shrink-0", label.Color }>
							{ label.Name }
						</span>
					}
				}
			</div>
			<div class="flex items-center justify-end shrink-0 text-muted-foreground tabular-nums" data-mail-table-cell="date">
				<span class={ templ.Classes("min-w-12 text-right", templ.KV("text-primary font-medium", !email.IsRead)) }>{ email.Date }</span>
			</div>
		</a>
	</div>
}

templ MailListEmpty() {
	<div class="flex flex-col items-center justify-center py-20 px-4 text-center">
		<div class="empty-icon-box size-16 rounded-2xl bg-muted/50 flex items-center justify-center mb-4 raised">
			@icon.Inbox(icon.Props{Class: "size-7 text-muted-foreground/40"})
		</div>
		<h3 class="font-semibold text-sm mb-1">No emails</h3>
		<p class="text-xs text-muted-foreground">Your inbox is empty</p>
	</div>
}

templ MailListItemsFragment(accounts []models.Account, emails []models.Email, folderID string, windowStart, windowEnd, totalCount int, displayTotalCount int, nextCursor string, hasMore bool, selectedEmailId string, senderDisplayMode string, viewMode string) {
	<div
		data-total-count={ fmt.Sprintf("%d", totalCount) }
		data-display-total-count={ fmt.Sprintf("%d", displayTotalCount) }
		data-window-start={ fmt.Sprintf("%d", windowStart) }
		data-window-end={ fmt.Sprintf("%d", windowEnd) }
		data-next-cursor={ nextCursor }
		data-has-more={ fmt.Sprintf("%t", hasMore) }
		data-folder-id={ folderID }
		data-view-mode={ mailListViewMode(viewMode) }
	>
		for i, email := range emails {
			@MailListItem(accounts, email, windowStart+i, &models.Email{ID: selectedEmailId}, senderDisplayMode, mailListViewMode(viewMode))
		}
	</div>
}

templ MailListThreadSubItems(items []models.ThreadItem, senderDisplayMode string) {
	<div>
		for _, item := range items {
			<div class="thread-sub-item" data-sub-email-id={ item.ID }>
				<a
					href={ templ.URL(fmt.Sprintf("/?email=%s", item.ID)) }
					hx-get={ mailViewPartialURL(item.ID, item.FolderID, true) }
					hx-target="#mail-view"
					hx-swap="innerHTML"
					class="flex items-start gap-2.5 px-3 py-1.5 cursor-pointer transition-colors hover:bg-muted/50"
				>
					<div class="flex items-center justify-center shrink-0" data-mail-table-cell="accountMarker">
						<span class="account-color-marker size-2.5 shrink-0" style={ accountColorStyle(item.AccountColor) }></span>
					</div>
					<div data-mail-table-cell="thread">
						@ContactAvatar(item.From, "size-5 rounded-full text-[9px] font-semibold shrink-0 mt-0.5", contactAvatarListFallback(item.IsRead))
					</div>
					<div class="flex-1 min-w-0">
						<div class="flex items-center justify-between gap-2">
							<span
								class={
									"text-xs truncate",
									templ.KV("font-medium text-foreground", !item.IsRead),
									templ.KV("text-foreground/60", item.IsRead),
								}
								data-mail-table-cell="from"
							>{ senderDisplay(item.From, senderDisplayMode) }</span>
							<span
								class={
									"text-xs truncate",
									templ.KV("font-medium text-foreground/75", !item.IsRead),
									templ.KV("text-foreground/55", item.IsRead),
								}
								data-mail-table-cell="to"
							>{ contactsDisplay(item.To, senderDisplayMode) }</span>
							<div class="flex items-center justify-center shrink-0" data-mail-table-cell="attachment">
								if item.HasAttachment {
									@icon.Paperclip(icon.Props{Class: "size-3 text-muted-foreground"})
								}
							</div>
							<div class="flex items-center justify-center shrink-0" data-mail-table-cell="starred">
								if item.IsStarred {
									@icon.Star(icon.Props{Class: "size-3 text-amber-500 fill-amber-500 drop-shadow-[0_1px_1px_rgba(180,120,0,0.4)]"})
								} else {
									<button class="opacity-0 group-hover:opacity-100 transition-opacity star-btn" data-email-id={ item.ID }>
										@icon.Star(icon.Props{Class: "size-3 text-muted-foreground/30"})
									</button>
								}
							</div>
							<div class="flex items-center gap-1.5 shrink-0" data-mail-table-cell="date">
								<span class="text-[11px] text-muted-foreground tabular-nums">{ item.Date }</span>
							</div>
						</div>
						<p class="text-[11px] text-muted-foreground truncate leading-relaxed" data-mail-table-cell="subject">{ item.Preview }</p>
					</div>
					if !item.IsRead {
						<div class="w-1.5 h-1.5 rounded-full bg-primary shrink-0"></div>
					}
				</a>
			</div>
		}
	</div>
}
